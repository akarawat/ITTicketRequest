@{
    ViewData["Title"] = "User Rights Management";
    var sessionJson = Context.Session.GetString("UserSession");
    ITTicketRequest.Models.UserSessionModel? user = null;
    if (!string.IsNullOrEmpty(sessionJson))
        user = System.Text.Json.JsonSerializer.Deserialize<ITTicketRequest.Models.UserSessionModel>(sessionJson);
}

@section Styles {
<style>
    .page-header h4 { font-weight:700; font-size:1.1rem; margin:0; }
    .filter-bar { background:#fff; border:1px solid #e0d6d6; border-radius:10px; padding:14px 20px; margin-bottom:16px; display:flex; flex-wrap:wrap; align-items:center; gap:12px; }
    .tbl-wrap { background:#fff; border:1px solid #e0d6d6; border-radius:10px; overflow:hidden; }
    table.ur-table { width:100%; border-collapse:collapse; font-size:13px; }
    table.ur-table thead th { background:#231f20; color:#fff; font-weight:600; padding:10px 12px; text-align:center; font-size:11.5px; letter-spacing:.4px; border-right:1px solid rgba(255,255,255,.15); white-space:nowrap; }
    table.ur-table thead th:first-child { text-align:left; }
    table.ur-table tbody tr { border-bottom:1px solid #f0f2f5; transition:background .1s; }
    table.ur-table tbody tr:hover { background:#fdf8f8; }
    table.ur-table tbody tr:last-child { border-bottom:none; }
    table.ur-table tbody td { padding:9px 12px; vertical-align:middle; text-align:center; border-right:1px solid #f0f2f5; }
    table.ur-table tbody td:first-child { text-align:left; }
    .user-name  { font-weight:600; font-size:13px; color:#1a2332; }
    .user-meta  { font-size:11.5px; color:#90a4ae; margin-top:1px; }
    .dept-badge { font-size:11px; padding:2px 8px; border-radius:20px; font-weight:600; background:#fef0f0; color:#ed1c24; white-space:nowrap; }

    /* Toggle switch */
    .toggle-wrap { display:flex; justify-content:center; align-items:center; }
    .toggle { position:relative; display:inline-block; width:36px; height:20px; }
    .toggle input { opacity:0; width:0; height:0; }
    .toggle-slider { position:absolute; cursor:pointer; inset:0; background:#cfd8dc; border-radius:20px; transition:background .2s; }
    .toggle-slider:before { content:''; position:absolute; width:14px; height:14px; left:3px; top:3px; background:#fff; border-radius:50%; transition:transform .2s; }
    .toggle input:checked + .toggle-slider { background:#ed1c24; }
    .toggle input:checked + .toggle-slider:before { transform:translateX(16px); }
    .toggle input:disabled + .toggle-slider { opacity:.5; cursor:default; }

    /* Role column colors */
    .col-auto  .toggle input:checked + .toggle-slider { background:#90a4ae; }
    .col-md    .toggle input:checked + .toggle-slider { background:#2e7d32; }
    .col-itpic .toggle input:checked + .toggle-slider { background:#6a1b9a; }
    .col-itm   .toggle input:checked + .toggle-slider { background:#0d47a1; }
    .col-itadm .toggle input:checked + .toggle-slider { background:#00695c; }
    .col-md4   .toggle input:checked + .toggle-slider { background:#e65100; }
    .col-sa    .toggle input:checked + .toggle-slider { background:#b71c1c; }

    .col-head-auto  { background:#607080 !important; }
    .col-head-md    { background:#2e7d32 !important; }
    .col-head-itpic { background:#6a1b9a !important; }
    .col-head-itm   { background:#0d47a1 !important; }
    .col-head-itadm { background:#00695c !important; }
    .col-head-md4   { background:#e65100 !important; }
    .col-head-sa    { background:#b71c1c !important; }

    /* Saving spinner */
    .saving-spin { display:none; width:14px; height:14px; border:2px solid #cfd8dc; border-top-color:#ed1c24; border-radius:50%; animation:spin .6s linear infinite; margin:0 auto; }
    @@keyframes spin { to { transform:rotate(360deg); } }

    /* Log panel */
    .log-panel { background:#fdf8f8; border:1px solid #e0d6d6; border-radius:10px; padding:16px 20px; margin-top:16px; }
    .log-panel h6 { font-weight:700; margin-bottom:12px; font-size:13px; color:#607080; text-transform:uppercase; letter-spacing:.5px; }
    .log-row { display:flex; align-items:center; gap:10px; font-size:12.5px; padding:5px 0; border-bottom:1px solid #f0f2f5; }
    .log-row:last-child { border-bottom:none; }
    .log-action-grant  { color:#2e7d32; font-weight:600; }
    .log-action-revoke { color:#b71c1c; font-weight:600; }
    .log-time { color:#90a4ae; font-size:11.5px; margin-left:auto; white-space:nowrap; }
    .empty-state { text-align:center; padding:40px; color:#90a4ae; font-size:13px; }

    /* Role filter chips */
    .role-chip { font-size:11.5px; font-weight:600; padding:3px 11px; border-radius:20px; border:1.5px solid #e0d6d6; background:#fff; color:#607080; cursor:pointer; white-space:nowrap; transition:all .15s; line-height:1.5; }
    .role-chip:hover { border-color:var(--chip-color,#ed1c24); color:var(--chip-color,#ed1c24); }
    .role-chip.active { background:var(--chip-color,#ed1c24); border-color:var(--chip-color,#ed1c24); color:#fff; }
    .role-chip[data-role=""].active { background:#231f20; border-color:#231f20; }
</style>
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-3 page-header">
    <div>
        <h4><i class="bi bi-shield-check me-2" style="color:#ed1c24"></i>User Rights Management</h4>
        <div style="font-size:12px;color:#90a4ae;margin-top:3px">
            System Admin only — Toggle role permissions per user
        </div>
    </div>
    <button class="btn btn-sm btn-outline-secondary" style="border-radius:8px;font-size:13px" onclick="loadUsers()">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

<!-- Filter bar -->
<div class="filter-bar">
    <input type="text" id="filter-search" class="form-control form-control-sm"
           style="width:220px" placeholder="Search Name / SAM Account / Department..."
           oninput="debounceSearch()" />
    <select id="filter-dept" class="form-select form-select-sm" style="width:180px"
            onchange="applyFilters()">
        <option value="">All Departments</option>
    </select>

    <!-- Role filter chips -->
    <div class="d-flex flex-wrap gap-1 align-items-center">
        <span style="font-size:12px;color:#90a4ae;white-space:nowrap">Role:</span>
        <button class="role-chip active" data-role="" onclick="setRoleFilter(this,'')">All</button>
        <button class="role-chip" data-role="hasRequester"        onclick="setRoleFilter(this,'hasRequester')"        style="--chip-color:#607080">Requester</button>
        <button class="role-chip" data-role="hasDeptManager"      onclick="setRoleFilter(this,'hasDeptManager')"      style="--chip-color:#2e7d32">Dept Manager</button>
        <button class="role-chip" data-role="hasCrossDept"        onclick="setRoleFilter(this,'hasCrossDept')"        style="--chip-color:#6a1b9a">IT PIC</button>
        <button class="role-chip" data-role="hasITManager"        onclick="setRoleFilter(this,'hasITManager')"        style="--chip-color:#0d47a1">IT Manager</button>
        <button class="role-chip" data-role="hasNetworkAdmin"     onclick="setRoleFilter(this,'hasNetworkAdmin')"     style="--chip-color:#00695c">IT Admin</button>
        <button class="role-chip" data-role="hasManagingDirector" onclick="setRoleFilter(this,'hasManagingDirector')" style="--chip-color:#e65100">Managing Director</button>
        <button class="role-chip" data-role="hasSysAdmin"         onclick="setRoleFilter(this,'hasSysAdmin')"         style="--chip-color:#b71c1c">System Admin</button>
    </div>
    <span id="user-count" style="font-size:12px;color:#90a4ae;margin-left:auto;white-space:nowrap"></span>
</div>

<!-- Table -->
<div class="tbl-wrap">
    <table class="ur-table" id="ur-table">
        <thead>
            <tr>
                <th style="min-width:220px;text-align:left">Employee Name</th>
                <th class="col-head-auto" style="width:90px">Requester<br><span style="font-size:10px;opacity:.8">(Auto)</span></th>
                <th class="col-head-md"   style="width:90px">Dept<br>Manager</th>
                <th class="col-head-itpic"style="width:90px">IT<br>PIC</th>
                <th class="col-head-itm"  style="width:90px">IT<br>Manager</th>
                <th class="col-head-itadm"style="width:90px">IT<br>Admin</th>
                <th class="col-head-md4"  style="width:90px">Managing<br>Director</th>
                <th class="col-head-sa"   style="width:90px">System<br>Admin</th>
                <th style="width:60px;background:#37474f !important"></th>
            </tr>
        </thead>
        <tbody id="ur-tbody">
            <tr><td colspan="9" class="text-center py-4">
                <div class="spinner-border spinner-border-sm me-2" style="color:#ed1c24"></div>
                <span style="color:#90a4ae;font-size:13px">Loading...</span>
            </td></tr>
        </tbody>
    </table>
</div>

<!-- Change Log -->
<div class="log-panel">
    <h6><i class="bi bi-clock-history me-2"></i>Recent Changes History</h6>
    <div id="log-content"><div class="empty-state">Loading...</div></div>
</div>

@section Scripts {
<script>
// FUNCODE mapping สำหรับ ITTicketRequest
// 1=Requester(auto), 8=DeptManager, 6=ITPIC, 7=ITManager, 5=ITAdmin, 4=ManagingDir, 9=SysAdmin
const ROLES = [
    { key:'hasRequester',        funCode:1, colClass:'col-auto',  auto:true  },
    { key:'hasDeptManager',      funCode:8, colClass:'col-md',    auto:false },
    { key:'hasCrossDept',        funCode:6, colClass:'col-itpic', auto:false },
    { key:'hasITManager',        funCode:7, colClass:'col-itm',   auto:false },
    { key:'hasNetworkAdmin',     funCode:5, colClass:'col-itadm', auto:false },
    { key:'hasManagingDirector', funCode:4, colClass:'col-md4',   auto:false },
    { key:'hasSysAdmin',         funCode:9, colClass:'col-sa',    auto:false },
];

const FUNNAME = {
    1:'Requester', 4:'Managing Director', 5:'IT Admin',
    6:'IT PIC',    7:'IT Manager',        8:'Dept Manager', 9:'System Admin'
};
const FUNNAME_BY_KEY = {
    hasRequester:'Requester',      hasDeptManager:'Dept Manager',
    hasCrossDept:'IT PIC',         hasITManager:'IT Manager',
    hasNetworkAdmin:'IT Admin',    hasManagingDirector:'Managing Director',
    hasSysAdmin:'System Admin'
};

let allUsers = [], activeRole = '', searchTimer = null;

function setRoleFilter(btn, roleKey) {
    document.querySelectorAll('.role-chip').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeRole = roleKey;
    applyFilters();
}

function debounceSearch() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applyFilters, 300);
}

function applyFilters() {
    const search = document.getElementById('filter-search').value.toLowerCase().trim();
    const dept   = document.getElementById('filter-dept').value;
    let filtered = allUsers;

    if (activeRole) filtered = filtered.filter(u => u[activeRole] === true);
    if (dept)       filtered = filtered.filter(u => u.department === dept);
    if (search)     filtered = filtered.filter(u =>
        (u.displayName || '').toLowerCase().includes(search) ||
        (u.samAcc      || '').toLowerCase().includes(search) ||
        (u.department  || '').toLowerCase().includes(search)
    );

    if (activeRole) {
        const chip = document.querySelector(`.role-chip[data-role="${activeRole}"]`);
        if (chip) chip.textContent = `${FUNNAME_BY_KEY[activeRole]} (${filtered.length})`;
    }
    renderTable(filtered);
}

async function loadUsers() {
    document.getElementById('ur-tbody').innerHTML =
        `<tr><td colspan="9" class="text-center py-4">
        <div class="spinner-border spinner-border-sm me-2" style="color:#ed1c24"></div>
        <span style="color:#90a4ae;font-size:13px">Loading...</span></td></tr>`;
    try {
        const res  = await fetch('/Admin/GetUsers');
        const data = await res.json();
        allUsers = data.users || [];

        const deptSel = document.getElementById('filter-dept');
        if (deptSel.options.length <= 1 && data.depts?.length)
            data.depts.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d; opt.textContent = d; deptSel.appendChild(opt);
            });

        updateChipCounts();
        applyFilters();
    } catch (e) {
        document.getElementById('ur-tbody').innerHTML =
            `<tr><td colspan="9" class="text-center py-3 text-danger">
             <i class="bi bi-exclamation-triangle me-2"></i>Error: ${e.message}</td></tr>`;
    }
}

function updateChipCounts() {
    document.querySelectorAll('.role-chip[data-role]').forEach(chip => {
        const role = chip.dataset.role;
        if (!role) { chip.textContent = `All (${allUsers.length})`; return; }
        const count = allUsers.filter(u => u[role] === true).length;
        chip.textContent = `${FUNNAME_BY_KEY[role]} (${count})`;
    });
}

function renderTable(users) {
    document.getElementById('user-count').textContent = `${users.length} users`;
    if (!users.length) {
        document.getElementById('ur-tbody').innerHTML =
            `<tr><td colspan="9"><div class="empty-state">
             <i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:8px;opacity:.3"></i>
             No employees found</div></td></tr>`;
        return;
    }

    document.getElementById('ur-tbody').innerHTML = users.map(u => `
        <tr data-sam="${u.samAcc}">
            <td>
                <div class="user-name">${u.displayName}</div>
                <div class="user-meta">${u.samAcc} · ${u.email || ''}</div>
                <span class="dept-badge">${u.department || ''}</span>
            </td>
            ${ROLES.map(r => `
            <td class="${r.colClass}">
                <div class="toggle-wrap">
                    <div id="spin-${u.samAcc}-${r.funCode}" class="saving-spin"></div>
                    <label class="toggle" style="display:none" id="tog-${u.samAcc}-${r.funCode}">
                        <input type="checkbox" ${u[r.key] ? 'checked' : ''} ${r.auto ? 'disabled' : ''}
                               onchange="toggleRole('${u.samAcc}',${r.funCode},this.checked,this)" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </td>`).join('')}
            <td>
                <button class="btn btn-sm btn-link p-0" style="font-size:12px;color:#90a4ae"
                        onclick="showLog('${u.samAcc}','${u.displayName}')">
                    <i class="bi bi-clock-history"></i>
                </button>
            </td>
        </tr>`).join('');

    setTimeout(() => {
        document.querySelectorAll('label[id^="tog-"]').forEach(el => el.style.display = 'inline-block');
    }, 50);
}

async function toggleRole(samAcc, funCode, checked, inputEl) {
    const action  = checked ? 'Grant' : 'Revoke';
    const spinEl  = document.getElementById(`spin-${samAcc}-${funCode}`);
    const togEl   = document.getElementById(`tog-${samAcc}-${funCode}`);
    spinEl.style.display = 'block'; togEl.style.display = 'none';
    inputEl.disabled = true;
    try {
        const res  = await fetch('/Admin/SetFunction', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ userLogon: samAcc, funCode, action })
        });
        const data = await res.json();
        if (!data.ok) { alert('Error: ' + data.msg); inputEl.checked = !checked; }
        else addLogEntry(samAcc, funCode, action);
    } catch { alert('Cannot connect to server'); inputEl.checked = !checked; }
    finally {
        inputEl.disabled = false;
        spinEl.style.display = 'none'; togEl.style.display = 'inline-block';
    }
}

async function loadLog(userLogon) {
    const res  = await fetch(`/Admin/GetLog${userLogon ? '?userLogon=' + userLogon : ''}`);
    const rows = await res.json();
    renderLog(rows);
}

function renderLog(rows) {
    const container = document.getElementById('log-content');
    if (!rows.length) { container.innerHTML = '<div class="empty-state">No changes recorded yet</div>'; return; }
    container.innerHTML = rows.slice(0,30).map(r => `
        <div class="log-row">
            <i class="bi ${r.action === 'Grant' ? 'bi-toggle2-on text-success' : 'bi-toggle2-off text-danger'}" style="font-size:14px"></i>
            <span style="font-weight:600;color:#1a2332">${r.userLogon}</span>
            <span class="log-action-${r.action.toLowerCase()}">${r.action}</span>
            <span style="color:#607080">${r.funName || 'FUNCODE=' + r.funCode}</span>
            <span style="color:#90a4ae">by ${r.updatedBy}</span>
            <span class="log-time">${formatDate(r.updatedAt)}</span>
        </div>`).join('');
}

function addLogEntry(samAcc, funCode, action) {
    const container = document.getElementById('log-content');
    const entry = document.createElement('div');
    entry.className = 'log-row';
    entry.innerHTML = `
        <i class="bi ${action === 'Grant' ? 'bi-toggle2-on text-success' : 'bi-toggle2-off text-danger'}" style="font-size:14px"></i>
        <span style="font-weight:600;color:#1a2332">${samAcc}</span>
        <span class="log-action-${action.toLowerCase()}">${action}</span>
        <span style="color:#607080">${FUNNAME[funCode] || 'FUNCODE=' + funCode}</span>
        <span class="log-time">${formatDate(new Date().toISOString())}</span>`;
    container.insertBefore(entry, container.firstChild);
    const empty = container.querySelector('.empty-state');
    if (empty) empty.remove();
}

async function showLog(samAcc, name) {
    document.getElementById('log-content').innerHTML =
        '<div class="empty-state"><div class="spinner-border spinner-border-sm me-2"></div>Loading...</div>';
    document.getElementById('ur-table').scrollIntoView({ behavior:'smooth', block:'end' });
    await loadLog(samAcc);
}

function formatDate(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'})
         + ' ' + d.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
}

loadUsers();
loadLog(null);
</script>
}
