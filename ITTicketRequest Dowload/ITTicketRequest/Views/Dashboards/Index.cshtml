@{
    ViewData["Title"] = "Dashboard";
    var sessionJson = Context.Session.GetString("UserSession");
    ITTicketRequest.Models.UserSessionModel? user = null;
    if (!string.IsNullOrEmpty(sessionJson))
        user = System.Text.Json.JsonSerializer.Deserialize<ITTicketRequest.Models.UserSessionModel>(sessionJson);
}
<style>
    .welcome-card { background:linear-gradient(135deg,#231f20 0%,#3d3535 100%);
                    border-radius:14px; padding:32px 36px; color:#fff; margin-bottom:24px;
                    border-bottom:3px solid #ed1c24; }
    .welcome-card h2 { font-weight:700; font-size:1.4rem; margin:0 0 4px; }
    .stat-card { background:#fff; border:1px solid #e0d6d6; border-radius:10px;
                 padding:16px 20px; display:flex; align-items:center; gap:14px; }
    .stat-icon { width:40px; height:40px; border-radius:10px;
                 display:flex; align-items:center; justify-content:center; font-size:18px; }
    .stat-num  { font-size:1.5rem; font-weight:700; line-height:1; }
    .stat-lbl  { font-size:12px; color:#607080; margin-top:2px; }
    .quick-card { background:#fff; border:1px solid #e0d6d6; border-radius:12px;
                  padding:24px; text-decoration:none; color:inherit; display:block;
                  transition:box-shadow .15s,transform .15s; }
    .quick-card:hover { box-shadow:0 4px 20px rgba(237,28,36,.12); transform:translateY(-2px); }
    .quick-card .icon-wrap { width:48px; height:48px; border-radius:12px;
                              display:flex; align-items:center; justify-content:center;
                              font-size:22px; margin-bottom:14px; }
    .quick-card h6 { font-weight:700; font-size:14px; margin:0 0 4px; }
    .quick-card p  { font-size:12.5px; color:#607080; margin:0; }
</style>

<!-- Welcome Banner -->
<div class="welcome-card">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h2>Hello, @(user?.FullName ?? "User") 👋</h2>
            <p style="opacity:.8;margin:0;font-size:14px">@(user?.Department) · @(user?.Email)</p>
        </div>
        <a href="/Ticket/Create" class="btn"
           style="background:#ed1c24;color:#fff;font-weight:700;border:none;padding:10px 24px;border-radius:8px">
            <i class="bi bi-plus-circle me-2"></i>New Ticket
        </a>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef0f0"><i class="bi bi-ticket" style="color:#ed1c24"></i></div>
            <div><div class="stat-num" id="stat-total"><span class="spinner-border spinner-border-sm text-secondary"></span></div><div class="stat-lbl">Total Tickets</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fff8e1"><i class="bi bi-clock-history" style="color:#e65100"></i></div>
            <div><div class="stat-num" id="stat-pending"><span class="spinner-border spinner-border-sm text-secondary"></span></div><div class="stat-lbl">Pending</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#e8f5e9"><i class="bi bi-check-circle" style="color:#2e7d32"></i></div>
            <div><div class="stat-num" id="stat-done"><span class="spinner-border spinner-border-sm text-secondary"></span></div><div class="stat-lbl">Completed</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fce4ec"><i class="bi bi-x-circle" style="color:#c62828"></i></div>
            <div><div class="stat-num" id="stat-rejected"><span class="spinner-border spinner-border-sm text-secondary"></span></div><div class="stat-lbl">Rejected</div></div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <a class="quick-card" href="/Ticket/Create">
            <div class="icon-wrap" style="background:#fef0f0"><i class="bi bi-plus-circle" style="color:#ed1c24"></i></div>
            <h6>New Ticket</h6><p>Submit IT Access Right / VPN / Programs</p>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a class="quick-card" href="/Ticket/MyTickets">
            <div class="icon-wrap" style="background:#e8f5e9"><i class="bi bi-list-check" style="color:#2e7d32"></i></div>
            <h6>My Tickets</h6><p>Track your submitted requests</p>
        </a>
    </div>
    @if (user?.IsAnyApprover == true)
    {
        <div class="col-6 col-md-3">
            <a class="quick-card" href="/Ticket/Pending">
                <div class="icon-wrap" style="background:#fff8e1"><i class="bi bi-bell" style="color:#e65100"></i></div>
                <h6>Pending</h6><p>Tickets awaiting your action</p>
            </a>
        </div>
    }
</div>

<!-- Recent Tickets -->
<div class="bg-white border rounded-3 p-4" style="border-color:#e0d6d6 !important">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="fw-bold mb-0">Recent Tickets</h6>
        <a href="/Ticket/MyTickets" style="font-size:13px;text-decoration:none">View all →</a>
    </div>
    <div id="recent-list">
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm me-2" style="color:#ed1c24"></div>
            <span style="color:#90a4ae;font-size:13px">Loading...</span>
        </div>
    </div>
</div>

@section Scripts {
<script>
const STATUS_COLOR = {
    PendingDeptMgr:       '#e65100',
    PendingManagingDir:   '#6a1b9a',
    PendingITMgr:         '#0d47a1',
    PendingITAdminAssign: '#00695c',
    PendingITPIC:         '#2e7d32',
    PendingITAdminClose:  '#37474f',
    Completed:            '#2e7d32',
    Rejected:             '#b71c1c'
};

async function loadStats() {
    try {
        const res  = await fetch('/Ticket/GetMyTickets');
        const rows = await res.json();

        document.getElementById('stat-total').textContent    = rows.length;
        document.getElementById('stat-pending').textContent  = rows.filter(r => !['Completed','Rejected'].includes(r.status)).length;
        document.getElementById('stat-done').textContent     = rows.filter(r => r.status === 'Completed').length;
        document.getElementById('stat-rejected').textContent = rows.filter(r => r.status === 'Rejected').length;

        const recent = rows.slice(0,5);
        const el     = document.getElementById('recent-list');

        if (!recent.length) {
            el.innerHTML = `<div class="text-center py-4" style="color:#90a4ae;font-size:13px">
                <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;opacity:.3"></i>
                No tickets yet — <a href="/Ticket/Create">Submit your first ticket</a>
            </div>`;
            return;
        }

        el.innerHTML = recent.map(r => `
            <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f0f2f5;font-size:13px">
                <span style="font-weight:700;color:#231f20;min-width:100px">${r.docNumber}</span>
                <span style="flex:1;color:#607080">${r.department}</span>
                <span style="font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;
                             background:${STATUS_COLOR[r.status] || '#607080'}22;
                             color:${STATUS_COLOR[r.status] || '#607080'}">${r.statusLabel}</span>
                <a href="/Ticket/Detail/${r.ticketId}" style="font-size:12px;color:#231f20;text-decoration:none">View →</a>
            </div>`).join('');
    } catch {
        document.getElementById('stat-total').textContent    = '—';
        document.getElementById('stat-pending').textContent  = '—';
        document.getElementById('stat-done').textContent     = '—';
        document.getElementById('stat-rejected').textContent = '—';
    }
}
loadStats();
</script>
}
