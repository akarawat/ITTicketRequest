@{ ViewData["Title"] = "My Tickets"; }

@section Styles {
<style>
    .filter-bar { background:#fff; border:1px solid #e0d6d6; border-radius:10px; padding:14px 20px; margin-bottom:16px; display:flex; flex-wrap:wrap; align-items:center; gap:12px; }
    .tbl-wrap { background:#fff; border:1px solid #e0d6d6; border-radius:10px; overflow:hidden; }
    table.tkt-table { width:100%; border-collapse:collapse; font-size:13.5px; }
    table.tkt-table thead th { background:#231f20; color:#fff; font-weight:700; padding:11px 14px; font-size:12px; text-transform:uppercase; letter-spacing:.5px; }
    table.tkt-table tbody tr { border-bottom:1px solid #f0f2f5; transition:background .1s; }
    table.tkt-table tbody tr:hover { background:#fdf8f8; }
    table.tkt-table tbody td { padding:11px 14px; vertical-align:middle; }
    .doc-num { font-weight:700; color:#231f20; }
    .req-tag { font-size:11px; padding:2px 8px; border-radius:20px; font-weight:600; margin-right:3px; }
    .tag-computer { background:#e3f2fd; color:#0d47a1; }
    .tag-email    { background:#fce4ec; color:#c62828; }
    .tag-network  { background:#e8f5e9; color:#2e7d32; }
    .tag-programs { background:#fff8e1; color:#e65100; }
    .tag-vpn      { background:#fef0f0; color:#ed1c24; }
    .status-badge { font-size:11px; padding:3px 10px; border-radius:20px; font-weight:600; white-space:nowrap; }
    .s-pending    { background:#fff8e1; color:#e65100; }
    .s-completed  { background:#e8f5e9; color:#2e7d32; }
    .s-rejected   { background:#ffebee; color:#b71c1c; }
    .s-itpic      { background:#e8f5e9; color:#2e7d32; }
    .s-itadmin    { background:#e0f2f1; color:#00695c; }
    .empty-state  { text-align:center; padding:60px 20px; color:#90a4ae; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 style="font-weight:700;margin:0">
        <i class="bi bi-list-check me-2" style="color:#ed1c24"></i>My Tickets
    </h4>
    <a href="/Ticket/Create" class="btn btn-sm"
       style="background:#ed1c24;color:#fff;border:none;border-radius:8px;font-size:13px">
        <i class="bi bi-plus-circle me-1"></i>New Ticket
    </a>
</div>

<div class="filter-bar">
    <input type="text" id="filter-search" class="form-control form-control-sm"
           style="width:220px" placeholder="Search Doc No. / Name..."
           oninput="filterTable()" />
    <select id="filter-status" class="form-select form-select-sm" style="width:200px"
            onchange="filterTable()">
        <option value="">All Statuses</option>
        <option value="pending">In Progress</option>
        <option value="Completed">Completed</option>
        <option value="Rejected">Rejected</option>
    </select>
    <span id="row-count" class="ms-auto" style="font-size:12px;color:#90a4ae"></span>
</div>

<div class="tbl-wrap">
    <table class="tkt-table">
        <thead>
            <tr>
                <th style="width:120px">Doc No.</th>
                <th>Request Items</th>
                <th>Status</th>
                <th style="width:110px">Submitted</th>
                <th style="width:110px">Completed</th>
                <th style="width:60px"></th>
            </tr>
        </thead>
        <tbody id="tkt-tbody">
            <tr><td colspan="6" class="text-center py-4">
                <div class="spinner-border spinner-border-sm me-2" style="color:#ed1c24"></div>
                <span style="color:#90a4ae;font-size:13px">Loading...</span>
            </td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
let allRows = [];

const STATUS_LABEL = {
    PendingDeptMgr:       'Pending Dept Manager',
    PendingManagingDir:   'Pending Managing Director',
    PendingITMgr:         'Pending IT Manager',
    PendingITAdminAssign: 'Pending IT Admin (Assign PIC)',
    PendingITPIC:         'In Progress — IT PIC',
    PendingITAdminClose:  'Pending IT Admin (Close)',
    Completed: 'Completed', Rejected: 'Rejected'
};

const STATUS_CLASS = {
    Completed: 's-completed', Rejected: 's-rejected',
    PendingITPIC: 's-itpic', PendingITAdminClose: 's-itadmin'
};

async function loadTickets() {
    try {
        const res  = await fetch('/Ticket/GetMyTickets');
        allRows    = await res.json();
        filterTable();
    } catch {
        document.getElementById('tkt-tbody').innerHTML =
            `<tr><td colspan="6" class="text-center py-4 text-danger">
             <i class="bi bi-exclamation-triangle me-2"></i>Error loading data</td></tr>`;
    }
}

function filterTable() {
    const search = document.getElementById('filter-search').value.toLowerCase();
    const status = document.getElementById('filter-status').value;

    let rows = allRows.filter(r => {
        const matchSearch = !search || r.docNumber.toLowerCase().includes(search);
        const matchStatus = !status
            ? true
            : status === 'pending'
                ? !['Completed','Rejected'].includes(r.status)
                : r.status === status;
        return matchSearch && matchStatus;
    });

    document.getElementById('row-count').textContent = `${rows.length} records`;

    if (!rows.length) {
        document.getElementById('tkt-tbody').innerHTML =
            `<tr><td colspan="6"><div class="empty-state">
             <i class="bi bi-inbox" style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:.3"></i>
             No tickets found</div></td></tr>`;
        return;
    }

    document.getElementById('tkt-tbody').innerHTML = rows.map(r => `
        <tr>
            <td><span class="doc-num">${r.docNumber}</span></td>
            <td>
                ${r.reqComputer ? '<span class="req-tag tag-computer">Computer</span>':''}
                ${r.reqEmail    ? '<span class="req-tag tag-email">Email</span>':''}
                ${r.reqNetwork  ? '<span class="req-tag tag-network">Network</span>':''}
                ${r.reqPrograms ? '<span class="req-tag tag-programs">Programs</span>':''}
                ${r.reqVPN      ? '<span class="req-tag tag-vpn">VPN</span>':''}
            </td>
            <td>
                <span class="status-badge ${STATUS_CLASS[r.status] || 's-pending'}">
                    ${STATUS_LABEL[r.status] || r.status}
                </span>
            </td>
            <td style="color:#607080;font-size:12.5px">${fmt(r.createdAt)}</td>
            <td style="color:#607080;font-size:12.5px">${r.completedAt ? fmt(r.completedAt) : '—'}</td>
            <td>
                <a href="/Ticket/Detail/${r.ticketId}"
                   style="font-size:12px;padding:4px 12px;border-radius:6px;border:1px solid #e0d6d6;color:#231f20;text-decoration:none;background:#fff">
                    <i class="bi bi-eye"></i>
                </a>
            </td>
        </tr>`).join('');
}

function fmt(iso) {
    return new Date(iso).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'});
}

loadTickets();
</script>
}
