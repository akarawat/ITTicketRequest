@{
    ViewData["Title"] = "Ticket Detail";
}
@{
    var sessionJson = Context.Session.GetString("UserSession");
    ITTicketRequest.Models.UserSessionModel? user = null;
    if (!string.IsNullOrEmpty(sessionJson))
        user = System.Text.Json.JsonSerializer.Deserialize<ITTicketRequest.Models.UserSessionModel>(sessionJson);
    var currentSam = user?.SamAcc ?? "";
    var isITAdmin = user?.IsITAdmin == true || user?.IsAdmin == true;
    var isITPIC = user?.IsITPIC == true;
}

@section Styles {
    <style>
        .detail-card {
            background: #fff;
            border: 1px solid #e0d6d6;
            border-radius: 12px;
            padding: 24px 28px;
            margin-bottom: 20px;
        }

        .section-label {
            font-weight: 700;
            font-size: 11px;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: #ed1c24;
            border-bottom: 2px solid #fef0f0;
            padding-bottom: 6px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-row {
            display: flex;
            margin-bottom: 8px;
            font-size: 13.5px;
        }

        .info-label {
            color: #90a4ae;
            min-width: 140px;
            flex-shrink: 0;
        }

        .info-val {
            color: #231f20;
            font-weight: 500;
        }

        .req-tag {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 20px;
            font-weight: 600;
            margin-right: 4px;
        }

        .tag-computer {
            background: #e3f2fd;
            color: #0d47a1;
        }

        .tag-email {
            background: #fce4ec;
            color: #c62828;
        }

        .tag-network {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .tag-programs {
            background: #fff8e1;
            color: #e65100;
        }

        .tag-vpn {
            background: #fef0f0;
            color: #ed1c24;
        }

        .workflow-steps {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .wf-step {
            display: flex;
            gap: 16px;
            position: relative;
        }

            .wf-step:not(:last-child)::before {
                content: '';
                position: absolute;
                left: 15px;
                top: 32px;
                width: 2px;
                height: calc(100% - 8px);
                background: #f0f2f5;
                z-index: 0;
            }

        .wf-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            position: relative;
            z-index: 1;
        }

            .wf-dot.done {
                background: #e8f5e9;
                color: #2e7d32;
                border: 2px solid #2e7d32;
            }

            .wf-dot.current {
                background: #fff8e1;
                color: #e65100;
                border: 2px solid #e65100;
                animation: pulse-dot 1.5s infinite;
            }

            .wf-dot.waiting {
                background: #f4f6fa;
                color: #cfd8dc;
                border: 2px solid #e0d6d6;
            }

            .wf-dot.rejected {
                background: #ffebee;
                color: #b71c1c;
                border: 2px solid #b71c1c;
            }

        @@keyframes pulse-dot {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(230,81,0,.3)
            }

            50% {
                box-shadow: 0 0 0 6px rgba(230,81,0,0)
            }
        }

        .wf-body {
            flex: 1;
            padding: 0 0 20px 0;
        }

        .wf-role {
            font-weight: 700;
            font-size: 13px;
            color: #231f20;
        }

        .wf-name {
            font-size: 12px;
            color: #607080;
            margin-top: 2px;
        }

        .wf-action-done {
            font-size: 11px;
            font-weight: 700;
            color: #2e7d32;
            background: #e8f5e9;
            padding: 2px 8px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 4px;
        }

        .wf-action-rejected {
            font-size: 11px;
            font-weight: 700;
            color: #b71c1c;
            background: #ffebee;
            padding: 2px 8px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 4px;
        }

        .wf-action-current {
            font-size: 11px;
            font-weight: 700;
            color: #e65100;
            background: #fff8e1;
            padding: 2px 8px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 4px;
        }

        .wf-remark {
            font-size: 12px;
            color: #607080;
            background: #f9f6f6;
            border-radius: 6px;
            padding: 6px 10px;
            margin-top: 6px;
        }

        .btn-approve-lg {
            background: #2e7d32;
            color: #fff;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13.5px;
            cursor: pointer;
        }

        .btn-reject-lg {
            background: #fff;
            color: #b71c1c;
            border: 1.5px solid #ef9a9a;
            padding: 10px 28px;
            border-radius: 8px;
            font-size: 13.5px;
            cursor: pointer;
        }

        .btn-assign-lg {
            background: #231f20;
            color: #fff;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13.5px;
            cursor: pointer;
        }

        .btn-close-lg {
            background: #2e7d32;
            color: #fff;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13.5px;
            cursor: pointer;
        }

        .btn-return-lg {
            background: #e65100;
            color: #fff;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13.5px;
            cursor: pointer;
        }
        /* PIC list */
        .pic-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 12px;
            border-radius: 8px;
            margin-bottom: 6px;
            border: 1px solid #e0d6d6;
            font-size: 13px;
        }

            .pic-row.active {
                background: #f0faf9;
                border-color: #2e7d32;
            }

            .pic-row.closed {
                background: #f9f6f6;
                border-color: #cfd8dc;
                opacity: .8;
            }

        .pic-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #2e7d32;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            flex-shrink: 0;
        }

            .pic-avatar.closed {
                background: #90a4ae;
            }
        /* Checkbox list ใน Modal */
        .pic-check-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 8px;
            border: 1px solid #e0d6d6;
            margin-bottom: 6px;
            cursor: pointer;
            background: #fff;
            transition: background .15s,border-color .15s;
        }

            .pic-check-item:hover {
                background: #f0faf9;
            }

            .pic-check-item.selected {
                background: #e8f5e9;
                border-color: #2e7d32;
            }

            .pic-check-item input[type=checkbox] {
                width: 16px;
                height: 16px;
                accent-color: #2e7d32;
                flex-shrink: 0;
            }
    </style>
}

<div id="loading-state" class="text-center py-5">
    <div class="spinner-border" style="color:#ed1c24"></div>
    <div style="color:#90a4ae;font-size:13px;margin-top:12px">Loading details...</div>
</div>

<div id="detail-content" style="display:none">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <a href="/Ticket/MyTickets" style="font-size:13px;color:#607080;text-decoration:none">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <h4 id="hdr-docnum" style="font-weight:700;margin:8px 0 0;color:#231f20"></h4>
        </div>
        <span id="hdr-status" class="badge" style="font-size:13px;padding:8px 16px"></span>
    </div>

    <div class="row g-4">
        <!-- Left -->
        <div class="col-lg-7">
            <div class="detail-card">
                <div class="section-label"><i class="bi bi-person-badge"></i>Requester Information</div>
                <div class="info-row"><span class="info-label">Name</span><span class="info-val" id="d-name"></span></div>
                <div class="info-row"><span class="info-label">Department</span><span class="info-val" id="d-dept"></span></div>
                <div class="info-row"><span class="info-label">Email</span><span class="info-val" id="d-email"></span></div>
                <div class="info-row"><span class="info-label">Reason</span><span class="info-val" id="d-reason"></span></div>
                <div class="info-row"><span class="info-label">Submitted</span><span class="info-val" id="d-date"></span></div>
            </div>
            <div class="detail-card">
                <div class="section-label"><i class="bi bi-list-check"></i>Requested Items</div>
                <div id="d-items"></div>
            </div>
            <!-- IT PIC List — แสดงเมื่อมีการ Assign แล้ว -->
            <div class="detail-card" id="pic-card" style="display:none">
                <div class="section-label"><i class="bi bi-people"></i>IT Person Incharge</div>
                <div id="pic-list"></div>
            </div>
        </div>

        <!-- Right -->
        <div class="col-lg-5">
            <div class="detail-card">
                <div class="section-label"><i class="bi bi-diagram-3"></i>Approval Workflow</div>
                <div class="workflow-steps" id="workflow-steps"></div>
            </div>
            <div id="action-panel" class="detail-card" style="display:none">
                <div class="section-label"><i class="bi bi-pencil-square"></i>Action</div>
                <div id="action-buttons" class="d-flex gap-2 flex-wrap"></div>
            </div>
        </div>
    </div>
</div>

<!-- Action Modal (Approve / Reject / CloseTask) -->
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;overflow:hidden">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h6 class="fw-bold" id="modal-title">Confirm</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div id="modal-desc" style="font-size:13.5px;color:#607080;margin-bottom:14px"></div>
                <label class="form-label fw-bold" style="font-size:13px">Remark (optional)</label>
                <textarea id="modal-remark" class="form-control" rows="3" placeholder="Enter reason / comments..."></textarea>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="modal-confirm" class="btn btn-sm" style="border-radius:8px;font-weight:700;padding:8px 24px">Confirm</button>
            </div>
        </div>
    </div>
</div>

<!-- Assign IT PIC Modal — Checkbox list -->
<div class="modal fade" id="assignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:500px">
        <div class="modal-content" style="border-radius:12px;overflow:hidden">
            <div style="background:#231f20;padding:20px 24px;display:flex;align-items:center;gap:12px">
                <div style="width:40px;height:40px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center">
                    <i class="bi bi-people" style="color:#fff;font-size:18px"></i>
                </div>
                <div>
                    <div style="color:#fff;font-weight:700;font-size:15px">Assign IT Person Incharge</div>
                    <div style="color:rgba(255,255,255,.7);font-size:12px">Select one or more IT PIC for this ticket</div>
                </div>
            </div>
            <div class="modal-body p-4">
                <!-- Checkbox list -->
                <label class="form-label fw-bold" style="font-size:13px">
                    Select IT PIC <span class="text-danger">*</span>
                    <span id="assign-count" style="font-size:11px;color:#2e7d32;font-weight:400;margin-left:8px"></span>
                </label>
                <div id="pic-checkbox-list" style="max-height:280px;overflow-y:auto;margin-bottom:16px">
                    <div class="text-center py-3" style="color:#90a4ae">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                    </div>
                </div>
                <label class="form-label fw-bold" style="font-size:13px">Remark (optional)</label>
                <textarea id="assign-remark" class="form-control" rows="2" placeholder="Assignment notes..."></textarea>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0 d-flex justify-content-between align-items-center">
                <span id="assign-warn" style="font-size:12px;color:#e65100;display:none">
                    <i class="bi bi-exclamation-triangle me-1"></i>Please select at least 1 IT PIC
                </span>
                <div class="d-flex gap-2 ms-auto">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="assign-confirm"
                            style="background:#231f20;color:#fff;border:none;border-radius:8px;padding:8px 24px;font-size:13px;font-weight:700;cursor:pointer">
                        <i class="bi bi-person-check me-2"></i>Assign &amp; Send Email
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const TICKET_ID    = '@ViewBag.TicketId';
        const CURRENT_SAM  = '@currentSam';
        const IS_IT_ADMIN  = @(isITAdmin ? "true" : "false");
        const IS_IT_PIC    = @(isITPIC ? "true" : "false");

        const actionModal = new bootstrap.Modal(document.getElementById('actionModal'));
        const assignModal = new bootstrap.Modal(document.getElementById('assignModal'));
        let   pendingAction = null;

        const STATUS_COLOR = {
            PendingDeptMgr:'#e65100', PendingManagingDir:'#6a1b9a',
            PendingITMgr:'#0d47a1',  PendingITAdminAssign:'#00695c',
            PendingITPIC:'#2e7d32',  PendingITAdminClose:'#37474f',
            Completed:'#2e7d32',     Rejected:'#b71c1c'
        };
        const STATUS_LABEL = {
            PendingDeptMgr:'Pending Dept Manager', PendingManagingDir:'Pending Managing Director',
            PendingITMgr:'Pending IT Manager',     PendingITAdminAssign:'Pending IT Admin (Assign PIC)',
            PendingITPIC:'In Progress — IT PIC',   PendingITAdminClose:'Pending IT Admin (Close)',
            Completed:'Completed', Rejected:'Rejected'
        };

        const FLOW_STEPS = (reqVPN) => {
            const steps = [{ status:'PendingDeptMgr', role:'Department Manager', funCode:8 }];
            if (reqVPN) steps.push({ status:'PendingManagingDir', role:'Managing Director', funCode:4 });
            steps.push(
                { status:'PendingITMgr',         role:'IT Manager',              funCode:7 },
                { status:'PendingITAdminAssign', role:'IT Admin (Assign PIC)',    funCode:5 },
                { status:'PendingITPIC',         role:'IT Person Incharge (IT PIC)', funCode:6 },
                { status:'PendingITAdminClose',  role:'IT Admin (Close Ticket)', funCode:9 },
                { status:'Completed',            role:'Completed',                funCode:0 }
            );
            return steps;
        };

        const STATUS_ORDER = ['PendingDeptMgr','PendingManagingDir','PendingITMgr',
            'PendingITAdminAssign','PendingITPIC','PendingITAdminClose','Completed','Rejected'];

        // ── Render Item Details ─────────────────────────────────────────────
        function renderItems(t, drives, programs) {
            let html = '';

            // ── New Computer ────────────────────────────────────────────────
            if (t.reqComputer) html += `
                <div class="item-block">
                    <div class="item-block-hdr">
                        <i class="bi bi-laptop" style="color:#0d47a1"></i>
                        <span style="color:#0d47a1">New Computer</span>
                    </div>
                    <div class="item-block-body">
                        <div class="d-flex gap-4 flex-wrap">
                            <div>
                                <div style="font-size:11px;color:#90a4ae;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Type</div>
                                <div style="font-weight:600;margin-top:2px">${t.computerType || '—'}</div>
                            </div>
                            <div style="flex:1">
                                <div style="font-size:11px;color:#90a4ae;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Special Requirements</div>
                                <div style="margin-top:2px;color:#607080">${t.computerNote || '—'}</div>
                            </div>
                        </div>
                    </div>
                </div>`;

            // ── Email Account ───────────────────────────────────────────────
            if (t.reqEmail) html += `
                <div class="item-block">
                    <div class="item-block-hdr">
                        <i class="bi bi-envelope-at" style="color:#c62828"></i>
                        <span style="color:#c62828">Email Account</span>
                    </div>
                    <div class="item-block-body">
                        <div style="font-size:11px;color:#90a4ae;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Requested Email</div>
                        <div style="font-weight:600;margin-top:4px">
                            <i class="bi bi-at me-1" style="color:#c62828"></i>
                            ${t.emailRequest ? t.emailRequest + '@@berninathailand.com' : '—'}
                        </div>
                    </div>
                </div>`;

            // ── Network Drive ───────────────────────────────────────────────
            if (t.reqNetwork) {
                const activeDrives = (drives || []).filter(d =>
                    d.driveRead || d.driveWrite || d.customPath);
                html += `
                <div class="item-block">
                    <div class="item-block-hdr">
                        <i class="bi bi-hdd-network" style="color:#2e7d32"></i>
                        <span style="color:#2e7d32">Network Drive</span>
                    </div>
                    <div class="item-block-body">
                        ${activeDrives.length ? `
                        <div class="table-responsive">
                            <table class="drive-tbl">
                                <thead><tr>
                                    <th style="text-align:left;width:80px">Drive</th>
                                    <th style="text-align:left">Description / Path</th>
                                    <th style="width:70px">Read</th>
                                    <th style="width:70px">Write</th>
                                </tr></thead>
                                <tbody>
                                    ${activeDrives.map(d => `
                                    <tr>
                                        <td><span style="font-weight:700;color:#ed1c24">${d.drive}:</span></td>
                                        <td style="text-align:left;color:#607080">${d.customPath || driveDesc(d.drive)}</td>
                                        <td>${d.driveRead ? '<i class="bi bi-check-circle-fill" style="color:#2e7d32"></i>' : '<i class="bi bi-dash" style="color:#cfd8dc"></i>'}</td>
                                        <td>${d.driveWrite ? '<i class="bi bi-check-circle-fill" style="color:#2e7d32"></i>' : '<i class="bi bi-dash" style="color:#cfd8dc"></i>'}</td>
                                    </tr>`).join('')}
                                </tbody>
                            </table>
                        </div>` : '<span style="color:#90a4ae;font-size:13px">No drives selected</span>'}
                    </div>
                </div>`;
            }

            // ── Programs ────────────────────────────────────────────────────
            if (t.reqPrograms) {
                const stdProgs = ['Microsoft Windows','Kaspersky','Driver Printer'];
                const allProgs = (programs || []).map(p => p.programName);
                html += `
                <div class="item-block">
                    <div class="item-block-hdr">
                        <i class="bi bi-grid-3x3-gap" style="color:#e65100"></i>
                        <span style="color:#e65100">Programs</span>
                        <span style="font-size:11px;font-weight:400;color:#90a4ae">${allProgs.length} items</span>
                    </div>
                    <div class="item-block-body">
                        <div style="display:flex;flex-wrap:wrap;gap:4px">
                            ${allProgs.map(p =>
                                `<span class="prog-chip ${stdProgs.includes(p) ? 'std' : ''}">
                                    ${stdProgs.includes(p) ? '<i class="bi bi-lock me-1" style="font-size:10px"></i>' : ''}${p}
                                 </span>`).join('')}
                            ${t.programOther ? `<span class="prog-chip" style="background:#f3e5f5;color:#6a1b9a;border-color:#ce93d8">
                                <i class="bi bi-plus me-1"></i>${t.programOther}</span>` : ''}
                        </div>
                    </div>
                </div>`;
            }

            // ── VPN ─────────────────────────────────────────────────────────
            if (t.reqVPN) html += `
                <div class="item-block">
                    <div class="item-block-hdr">
                        <i class="bi bi-shield-shaded" style="color:#ed1c24"></i>
                        <span style="color:#ed1c24">VPN — FortiClient</span>
                    </div>
                    <div class="item-block-body">
                        <div class="d-flex gap-4 flex-wrap">
                            <div>
                                <div style="font-size:11px;color:#90a4ae;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Access Type</div>
                                <div style="font-weight:600;margin-top:2px">
                                    <span style="background:${t.vpnType==='Permanent'?'#e3f2fd':'#fce4ec'};
                                                 color:${t.vpnType==='Permanent'?'#0d47a1':'#c62828'};
                                                 font-size:12px;padding:2px 10px;border-radius:20px">
                                        ${t.vpnType || '—'}
                                    </span>
                                </div>
                            </div>
                            ${t.vpnType === 'Temporary' ? `
                            <div>
                                <div style="font-size:11px;color:#90a4ae;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Period</div>
                                <div style="font-weight:600;margin-top:2px;color:#607080">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    ${t.vpnFrom ? fmtDate(t.vpnFrom) : '—'} → ${t.vpnTo ? fmtDate(t.vpnTo) : '—'}
                                </div>
                            </div>` : ''}
                        </div>
                    </div>
                </div>`;

            return html || '<span style="color:#90a4ae;font-size:13px">No items requested</span>';
        }

        function driveDesc(code) {
            const map = {S:'Share (Common)',V:'Department Directory',T:'BTMS',
                         X:'Company Info (Standard)',W:'BT - Structure',U:'Own Directory',K:'Drawing'};
            return map[code] || code;
        }

        function fmtDate(iso) {
            if (!iso) return '—';
            return new Date(iso).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'});
        }

        async function loadDetail() {
            try {
                const res  = await fetch(`/Ticket/GetDetail/${TICKET_ID}`);
                const data = await res.json();
                const t    = data.ticket;

                document.getElementById('loading-state').style.display  = 'none';
                document.getElementById('detail-content').style.display = 'block';

                // Header
                document.getElementById('hdr-docnum').textContent = t.docNumber;
                const hdrStatus = document.getElementById('hdr-status');
                hdrStatus.textContent          = STATUS_LABEL[t.status] || t.status;
                hdrStatus.style.background     = STATUS_COLOR[t.status] + '22';
                hdrStatus.style.color          = STATUS_COLOR[t.status] || '#607080';

                // Info
                document.getElementById('d-name').textContent   = t.requesterName;
                document.getElementById('d-dept').textContent   = t.department;
                document.getElementById('d-email').textContent  = t.requesterEmail;
                document.getElementById('d-reason').textContent = t.reason || '—';
                document.getElementById('d-date').textContent   = fmt(t.createdAt);

                // Items — แสดงรายละเอียดแต่ละ Item
                document.getElementById('d-items').innerHTML = renderItems(t, data.drives, data.programs);

                // IT PIC List
                renderPICList(data.picList || [], t.status);

                // Workflow
                renderWorkflow(t, data.logs, data.picList || []);

                // Action panel
                renderActionPanel(t, data.picList || []);

            } catch {
                document.getElementById('loading-state').innerHTML =
                    `<div class="text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Unable to load data</div>`;
            }
        }

        // ── PIC List Card ───────────────────────────────────────────────────
        function renderPICList(picList, status) {
            if (!picList.length) return;
            document.getElementById('pic-card').style.display = 'block';
            const el = document.getElementById('pic-list');

            const activeCount = picList.filter(p => p.status === 'Active').length;
            const closedCount = picList.filter(p => p.status === 'Closed').length;

            el.innerHTML = `
                <div style="font-size:12px;color:#607080;margin-bottom:12px">
                    Total: <b>${picList.length}</b> PIC &nbsp;·&nbsp;
                    <span style="color:#2e7d32">✓ Closed: ${closedCount}</span> &nbsp;·&nbsp;
                    <span style="color:#e65100">⏳ Active: ${activeCount}</span>
                </div>
                ${picList.map(p => {
                    const isClosed   = p.status === 'Closed';
                    const isReturned = p.status === 'Returned';
                    const initials = p.displayName.split(' ').slice(0,2).map(w => w[0]).join('');
                    const isMine   = p.samAcc.toLowerCase() === CURRENT_SAM.toLowerCase();
                    // แสดงปุ่มถ้า: เป็นตัวเอง + ยัง Active + Status เป็น PendingITPIC หรือ PendingITAdminClose
                    const canClose = isMine && !isClosed && !isReturned
                                  && (status === 'PendingITPIC' || status === 'PendingITAdminClose');
                    return `
                    <div class="pic-row ${isClosed ? 'closed' : 'active'}">
                        <div class="d-flex align-items-center gap-10" style="gap:10px">
                            <div class="pic-avatar ${isClosed || isReturned ? 'closed' : ''}">${initials}</div>
                            <div>
                                <div style="font-weight:600;font-size:13px">${p.displayName}</div>
                                <div style="font-size:11px;color:#607080">${p.email}</div>
                                ${p.status === 'Closed'
                            ? `<div style="font-size:11px;color:#2e7d32;margin-top:2px">
                                <i class="bi bi-check-circle me-1"></i>Closed ${fmt(p.closedAt)}
                                ${p.closeRemark ? `· <i>${p.closeRemark}</i>` : ''}
                               </div>`
                            : p.status === 'Returned'
                            ? `<div style="font-size:11px;color:#e65100;margin-top:2px">
                                <i class="bi bi-arrow-return-left me-1"></i>Returned ${fmt(p.closedAt)}
                                ${p.closeRemark ? `· <i>${p.closeRemark}</i>` : ''}
                               </div>`
                            : `<div style="font-size:11px;color:#0d47a1;margin-top:2px">
                                <i class="bi bi-clock me-1"></i>In Progress</div>`}
                            </div>
                        </div>
                        ${canClose ? `
                        <button class="btn-close-lg" style="font-size:12px;padding:5px 14px"
                                onclick="openCloseTaskModal()">
                            <i class="bi bi-check2-all me-1"></i>Close Task
                        </button>` : ''}
                    </div>`;
                }).join('')}`;
        }

        // ── Workflow Timeline ───────────────────────────────────────────────
        function renderWorkflow(t, logs, picList) {
            const steps  = FLOW_STEPS(t.reqVPN);
            const logMap = {};
            logs.forEach(l => { logMap[l.funCode] = logMap[l.funCode] || l; });

            document.getElementById('workflow-steps').innerHTML = steps.map(step => {
                const log       = logMap[step.funCode];
                const isDone    = log && (log.action === 'Approve' || log.action === 'Assign');
                const isCurrent = step.status === t.status;
                const isRej     = log && log.action === 'Reject';
                const isEnd     = step.status === 'Completed';

                let dotClass = 'waiting', icon = 'bi-circle';
                if (isEnd && t.status === 'Completed') { dotClass='done'; icon='bi-check-lg'; }
                else if (isRej)     { dotClass='rejected'; icon='bi-x-lg'; }
                else if (isDone)    { dotClass='done';     icon='bi-check-lg'; }
                else if (isCurrent) { dotClass='current';  icon='bi-clock'; }

                let actionLabel = '';
                if (isEnd && t.status === 'Completed')
                    actionLabel = `<span class="wf-action-done">✓ Completed</span>`;
                else if (isDone)
                    actionLabel = `<span class="wf-action-done">✓ ${log.action} ${log.actionAt ? '· '+fmt(log.actionAt):''}</span>`;
                else if (isRej)
                    actionLabel = `<span class="wf-action-rejected">✗ Rejected ${log.actionAt ? '· '+fmt(log.actionAt):''}</span>`;
                else if (isCurrent && !isEnd)
                    actionLabel = `<span class="wf-action-current">⏳ Awaiting</span>`;

                // แสดง PIC names ใน IT PIC step
                let picHtml = '';
                if (step.funCode === 6 && picList.length) {
                    picHtml = picList.map(p =>
                        `<div class="wf-name" style="color:${p.status==='Closed'?'#2e7d32':'#e65100'}">
                            ${p.status==='Closed'?'✓':'⏳'} ${p.displayName}
                        </div>`).join('');
                } else if (log?.assignedTo) {
                    picHtml = `<div class="wf-name" style="color:#2e7d32">→ ${log.assignedTo}</div>`;
                }

                const remarkHtml = log?.remark
                    ? `<div class="wf-remark"><i class="bi bi-chat-text me-1"></i>${log.remark}</div>` : '';

                return `
                <div class="wf-step">
                    <div class="wf-dot ${dotClass}"><i class="bi ${icon}"></i></div>
                    <div class="wf-body">
                        <div class="wf-role">${step.role}</div>
                        ${log?.approverName && step.funCode !== 6 ? `<div class="wf-name">${log.approverName}</div>` : ''}
                        ${picHtml}
                        ${actionLabel}
                        ${remarkHtml}
                    </div>
                </div>`;
            }).join('');
        }

        // ── Action Panel ────────────────────────────────────────────────────
        function renderActionPanel(t, picList) {
            const panel   = document.getElementById('action-panel');
            const buttons = document.getElementById('action-buttons');
            if (['Completed','Rejected'].includes(t.status)) return;

            // ── ซ่อนปุ่ม Action ถ้า User เป็นคนสร้าง Ticket นั้นเอง ────────
            const isOwnTicket = t.samAcc?.toLowerCase() === CURRENT_SAM.toLowerCase();
            if (isOwnTicket && !IS_IT_ADMIN) return;

            const isAssignStep    = t.status === 'PendingITAdminAssign';
            // IT PIC ยัง Active ได้แม้ Status = PendingITAdminClose (SP อาจเปลี่ยน Status เร็วเกินไป)
            const isITPICStep = t.status === 'PendingITPIC' || t.status === 'PendingITAdminClose';
            const isCloseStep     = t.status === 'PendingITAdminClose';

            // IT PIC — เช็คจาก picList โดยตรง (ไม่เช็ค IS_IT_PIC เพราะ user อาจไม่มี FUNCODE=6)
            if (isITPICStep) {
                const myPIC = picList.find(p => p.samAcc.toLowerCase() === CURRENT_SAM.toLowerCase()
                                             && p.status === 'Active');
                if (myPIC) {
                    panel.style.display = 'block';
                    buttons.innerHTML = `
                        <button class="btn-close-lg" onclick="openCloseTaskModal()">
                            <i class="bi bi-check2-all me-1"></i>Close Task
                        </button>
                        <button class="btn-return-lg" onclick="openReturnTaskModal()">
                            <i class="bi bi-arrow-return-left me-1"></i>Return Task
                        </button>`;
                    return;
                }
            }

            if (!IS_IT_ADMIN && !t.status.startsWith('Pending')) return;

            panel.style.display = 'block';

            if (isAssignStep && IS_IT_ADMIN) {
                buttons.innerHTML = `
                    <button class="btn-assign-lg" onclick="openAssignModal()">
                        <i class="bi bi-people me-2"></i>Assign IT PIC
                    </button>
                    <button class="btn-reject-lg" onclick="openActionModal('Reject')">
                        <i class="bi bi-x me-1"></i>Reject
                    </button>`;
            } else if (isCloseStep) {
                buttons.innerHTML = `
                    <button class="btn-approve-lg" onclick="openActionModal('Approve')">
                        <i class="bi bi-check2-all me-1"></i>Close Ticket
                    </button>
                    <button class="btn-reject-lg" onclick="openActionModal('Reject')">
                        <i class="bi bi-x me-1"></i>Reject
                    </button>`;
            } else if (!isITPICStep) {
                buttons.innerHTML = `
                    <button class="btn-approve-lg" onclick="openActionModal('Approve')">
                        <i class="bi bi-check me-1"></i>Approve
                    </button>
                    <button class="btn-reject-lg" onclick="openActionModal('Reject')">
                        <i class="bi bi-x me-1"></i>Reject
                    </button>`;
            }
        }

        // ── Modals ──────────────────────────────────────────────────────────
        function openActionModal(action) {
            pendingAction = action;
            const labels = { Approve:'Confirm Approval', Reject:'Confirm Rejection', CloseTask:'Close Task' };
            document.getElementById('modal-title').textContent = labels[action] || action;
            document.getElementById('modal-desc').textContent  = `${action} this ticket?`;
            const btn = document.getElementById('modal-confirm');
            btn.style.background = action === 'Reject' ? '#b71c1c' : '#2e7d32';
            btn.style.color = '#fff'; btn.style.border = 'none';
            btn.textContent = action === 'CloseTask' ? 'Confirm Close Task' : action;
            document.getElementById('modal-remark').value = '';
            actionModal.show();
        }

        function openCloseTaskModal() {
            openActionModal('CloseTask');
        }

        function openReturnTaskModal() {
            pendingAction = 'ReturnTask';
            document.getElementById('modal-title').textContent = 'Return Task';
            document.getElementById('modal-desc').innerHTML = `
                <div style="background:#fff3e0;border:1px solid #ffcc80;border-radius:8px;
                            padding:10px 14px;margin-bottom:10px;font-size:13px;color:#e65100">
                    <i class="bi bi-arrow-return-left me-2"></i>
                    <b>Return task to IT Admin for reassignment</b>
                </div>
                <span style="color:#607080;font-size:13px">
                    Please provide a reason so IT Admin can reassign appropriately.
                </span>`;
            const btn = document.getElementById('modal-confirm');
            btn.style.background = '#e65100';
            btn.style.color = '#fff';
            btn.style.border = 'none';
            btn.textContent = 'Confirm Return';
            document.getElementById('modal-remark').value = '';
            document.getElementById('modal-remark').placeholder = 'Reason for returning (e.g. not in my area of responsibility)';
            actionModal.show();
        }

        async function openAssignModal() {
            document.getElementById('pic-checkbox-list').innerHTML =
                `<div class="text-center py-3" style="color:#90a4ae">
                 <div class="spinner-border spinner-border-sm me-2"></div>Loading...</div>`;
            document.getElementById('assign-remark').value = '';
            document.getElementById('assign-count').textContent = '';
            document.getElementById('assign-warn').style.display = 'none';
            assignModal.show();

            const res  = await fetch('/Ticket/GetApprovers?funCode=6');
            const list = await res.json();
            const el   = document.getElementById('pic-checkbox-list');

            if (!list.length) {
                el.innerHTML = `<div style="color:#e65100;font-size:13px;padding:8px">No IT PIC available</div>`;
                return;
            }

            el.innerHTML = list.map((p, i) => `
                <div class="pic-check-item" id="pic-item-${i}" onclick="togglePICCheck(${i}, '${p.samAcc}')">
                    <input type="checkbox" id="pic-chk-${i}" value="${p.samAcc}"
                           onchange="updateCheckCount()" onclick="event.stopPropagation()" />
                    <div>
                        <div style="font-weight:600;font-size:13px;color:#1a2332">${p.displayName}</div>
                        <div style="font-size:11px;color:#607080">${p.email}</div>
                    </div>
                </div>`).join('');

            updateCheckCount();
        }

        function togglePICCheck(i, samAcc) {
            const chk  = document.getElementById(`pic-chk-${i}`);
            const item = document.getElementById(`pic-item-${i}`);
            chk.checked = !chk.checked;
            item.classList.toggle('selected', chk.checked);
            updateCheckCount();
        }

        function updateCheckCount() {
            const checked = document.querySelectorAll('#pic-checkbox-list input[type=checkbox]:checked').length;
            document.getElementById('assign-count').textContent = checked > 0 ? `(${checked} selected)` : '';
            document.getElementById('assign-warn').style.display = 'none';
        }

        document.getElementById('modal-confirm').onclick = async () => {
            const remark = document.getElementById('modal-remark').value;

            if (pendingAction === 'CloseTask') {
                const res  = await fetch('/Ticket/CloseITPICTask', {
                    method:'POST', headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({ requestId: TICKET_ID, remark })
                });
                const data = await res.json();
                actionModal.hide();
                if (data.ok) loadDetail();
                else alert('Error: ' + data.msg);
                return;
            }

            if (pendingAction === 'ReturnTask') {
                if (!remark.trim()) {
                    alert('Please provide a reason for returning the task.');
                    return;
                }
                const res  = await fetch('/Ticket/ReturnITPICTask', {
                    method:'POST', headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({ requestId: TICKET_ID, remark })
                });
                const data = await res.json();
                actionModal.hide();
                if (data.ok) loadDetail();
                else alert('Error: ' + data.msg);
                return;
            }

            const res  = await fetch('/Ticket/Approve', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ requestId: TICKET_ID, action: pendingAction, remark })
            });
            const data = await res.json();
            actionModal.hide();
            if (data.ok) loadDetail();
            else alert('Error: ' + data.msg);
        };

        document.getElementById('assign-confirm').onclick = async () => {
            const checked = [...document.querySelectorAll('#pic-checkbox-list input[type=checkbox]:checked')]
                            .map(c => c.value);
            if (!checked.length) {
                document.getElementById('assign-warn').style.display = 'block';
                return;
            }
            const remark = document.getElementById('assign-remark').value;
            const btn    = document.getElementById('assign-confirm');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Assigning...';

            const res  = await fetch('/Ticket/AssignITPIC', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ requestId: TICKET_ID, action: 'Assign', assignToList: checked, remark })
            });
            const data = await res.json();
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-person-check me-2"></i>Assign & Send Email';
            assignModal.hide();
            if (data.ok) loadDetail();
            else alert('Error: ' + data.msg);
        };

        function fmt(iso) {
            if (!iso) return '—';
            return new Date(iso).toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
        }

        loadDetail();
    </script>
}
